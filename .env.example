# ===================================================
#  KPI Health - Production Environment Template
#  คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงสำหรับ Production
#  !! NEVER commit .env !!
# ===================================================

# Database Server (Production)
# DB_HOST ไม่ต้องกรอก — docker-compose ใช้ host.docker.internal อัตโนมัติ
# (host.docker.internal = IP เครื่อง Windows/Mac ที่รัน Docker Desktop)
DB_HOST=
DB_PORT=3306
DB_NAME=khups_kpi_db
DB_USER=
DB_PASSWORD=

# Application Secret (ใช้ค่าสุ่มที่ยาวและซับซ้อน)
SECRET_KEY=
