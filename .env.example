# ===================================================
#  KPI Health - Production Environment Template
#  คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริงสำหรับ Production
#  !! NEVER commit .env !!
# ===================================================

# ---------------------------------------------------
#  Database Server (MySQL / MariaDB)
# ---------------------------------------------------
# DB_HOST ไม่ต้องกรอก — docker-compose ใช้ host.docker.internal อัตโนมัติ
# (host.docker.internal = IP เครื่อง Host ที่รัน Docker)
# ถ้าไม่ใช้ Docker ให้กรอก IP หรือ hostname ของ MySQL Server
DB_HOST=
DB_PORT=3306
DB_NAME=khups_kpi_db
DB_USER=
DB_PASSWORD=

# ---------------------------------------------------
#  Application Secret Key
# ---------------------------------------------------
# ใช้สำหรับ sign JWT Token — ต้องเป็นค่าสุ่มที่ยาวและซับซ้อน
# สร้างได้ด้วย: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=

# ---------------------------------------------------
#  SMTP Email (สำหรับแจ้งผลอนุมัติ/ปฏิเสธ/ลืมรหัสผ่าน)
# ---------------------------------------------------
# ถ้าไม่ตั้งค่า SMTP_HOST ระบบจะไม่ส่ง Email (ไม่ crash)
#
# สำหรับ Gmail:
#   1. เปิด 2-Step Verification ที่ https://myaccount.google.com/security
#   2. สร้าง App Password ที่ https://myaccount.google.com/apppasswords
#   3. ใส่ App Password (16 ตัว) ใน SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# ตัวอย่าง SMTP_FROM: ระบบ KPI สสจ.นครราชสีมา <your-email@gmail.com>
