# ===================================================
#  KPI Backend - Development Environment Template
#  คัดลอกไฟล์นี้เป็น .env.dev แล้วกรอกค่าของคุณ
#  !! DO NOT COMMIT .env.dev !! (gitignored)
# ===================================================

# ---------------------------------------------------
#  Database Server (Development)
# ---------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=khups_kpi_db
DB_USER=
DB_PASSWORD=

# ---------------------------------------------------
#  Application Secret Key (Development)
# ---------------------------------------------------
SECRET_KEY=dev_secret_key_change_me

# ---------------------------------------------------
#  Backend Port (Development)
# ---------------------------------------------------
# Frontend environment.ts ชี้มาที่ http://localhost:3000/khupskpi/api
PORT=3000

# ---------------------------------------------------
#  SMTP Email (ไม่บังคับ — ถ้าไม่ตั้งค่าระบบจะไม่ส่ง Email)
# ---------------------------------------------------
# สำหรับ Gmail: ใช้ App Password (ดูวิธีสร้างใน .env.example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------------------------------------------------
#  Application URL (สำหรับ link ในการแจ้งเตือน)
# ---------------------------------------------------
# ใส่ URL ของ Frontend (origin เท่านั้น ไม่ต้องมี path)
APP_URL=http://localhost:4200

# ---------------------------------------------------
#  Telegram Bot (แจ้งเตือนผู้สมัครใหม่)
# ---------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------
#  Admin Email (แจ้งเตือนผู้สมัครใหม่ — คั่นด้วย comma)
# ---------------------------------------------------
ADMIN_EMAILS=
