{
  "name": "kpi-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve --host 0.0.0.0 --port 4500",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "audit": "npm audit --omit=dev",
    "audit:fix": "npm audit fix --omit=dev"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.9.3",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fontsource/sarabun": "^5.2.8",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "apexcharts": "^5.6.0",
    "bootstrap": "^5.3.8",
    "ng-apexcharts": "^2.2.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.20",
    "tslib": "^2.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "autoprefixer": "^10.4.24",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
